---
import type { CaseStudy } from '../types/case-study.js';

export interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props;

const difficultyColors = {
  beginner: 'bg-emerald-100 text-emerald-800 border-emerald-200',
  intermediate: 'bg-amber-100 text-amber-800 border-amber-200',
  advanced: 'bg-red-100 text-red-800 border-red-200',
};

const difficultyIcons = {
  beginner: '●○○',
  intermediate: '●●○',
  advanced: '●●●',
};
---

<a
  href={`/case-studies/${caseStudy.id}`}
  class="group block bg-white rounded-xl border border-slate-200 shadow-sm hover:shadow-md hover:border-medical-300 transition-all duration-200 overflow-hidden"
>
  <!-- Header stripe -->
  <div class="h-2 bg-gradient-to-r from-medical-500 to-teal-500"></div>

  <div class="p-6">
    <!-- Badges row -->
    <div class="flex items-center gap-2 mb-3 flex-wrap">
      <span
        class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold border ${difficultyColors[caseStudy.difficulty]}`}
      >
        <span class="font-mono tracking-tight">{difficultyIcons[caseStudy.difficulty]}</span>
        {caseStudy.difficulty.charAt(0).toUpperCase() + caseStudy.difficulty.slice(1)}
      </span>
      <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 border border-slate-200">
        {caseStudy.specialty}
      </span>
      <span class="ml-auto flex items-center gap-1 text-xs text-slate-500">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        {caseStudy.estimatedTime} min
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-lg font-bold text-slate-800 group-hover:text-medical-700 transition-colors leading-snug">
      {caseStudy.title}
    </h3>
    <p class="text-sm font-medium text-medical-600 mb-2">{caseStudy.subtitle}</p>

    <!-- Description -->
    <p class="text-sm text-slate-600 leading-relaxed line-clamp-3 mb-4">
      {caseStudy.description}
    </p>

    <!-- Patient preview -->
    <div class="bg-slate-50 rounded-lg px-3 py-2.5 mb-4 border border-slate-100">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Patient</p>
      <p class="text-sm text-slate-700">
        <span class="font-medium">{caseStudy.patient.name}</span>
        <span class="text-slate-500"
          >, {caseStudy.patient.age}yo {caseStudy.patient.gender} — {caseStudy.patient.chiefComplaint}</span
        >
      </p>
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {
        caseStudy.tags.slice(0, 4).map((tag) => (
          <span class="px-2 py-0.5 rounded text-xs bg-medical-50 text-medical-700 border border-medical-100">
            {tag}
          </span>
        ))
      }
      {
        caseStudy.tags.length > 4 && (
          <span class="px-2 py-0.5 rounded text-xs bg-slate-50 text-slate-500">
            +{caseStudy.tags.length - 4} more
          </span>
        )
      }
    </div>

    <!-- Footer row -->
    <div class="flex items-center justify-between pt-3 border-t border-slate-100">
      <div class="flex items-center gap-1 text-xs text-slate-500">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.745 3.745 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.745 3.745 0 013.296-1.043A3.745 3.745 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.745 3.745 0 013.296 1.043 3.745 3.745 0 011.043 3.296A3.745 3.745 0 0121 12z"
          ></path>
        </svg>
        {caseStudy.learningObjectives.length} learning objectives
      </div>
      <span
        class="inline-flex items-center gap-1 text-sm font-semibold text-medical-600 group-hover:text-medical-800 transition-colors"
      >
        Begin case
        <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </span>
    </div>
  </div>
</a>
