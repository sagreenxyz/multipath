// ── Reference toggle (mobile) ─────────────────────────────────────────
function initRefToggle() {
  const toggleBtn = document.getElementById('ref-toggle');
  const modal = document.getElementById('ref-modal');
  const closeBtn = document.getElementById('ref-modal-close');

  toggleBtn?.addEventListener('click', () => {
    // On large screens, toggle sidebar visibility
    if (window.innerWidth >= 1024) {
      const sidebar = document.getElementById('ref-sidebar');
      sidebar?.classList.toggle('hidden');
    } else {
      modal?.classList.toggle('hidden');
    }
  });

  closeBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.classList.add('hidden');
  });
}

// ── Initialize ─────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  renderVitals(currentVitals);
  renderLabs(currentLabs);
  renderImaging(currentImaging);
  loadReferenceData();
  initAccordion();
  initRefToggle();

  // Start at first scene
  const firstScene = sceneMap.get(caseStudy.startSceneId);
  if (firstScene) renderScene(firstScene);
});
</script>

