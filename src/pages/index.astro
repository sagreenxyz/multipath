---
import Layout from '../layouts/Layout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import { allCaseStudies } from '../data/case-studies/index.js';
---

<Layout title="Home" description="Multipath — Multi-path clinical case study training for nursing students">
  <!-- Hero Section -->
  <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-medical-800 via-medical-700 to-teal-700 text-white mb-12 py-16 px-8 shadow-xl">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
        <circle cx="600" cy="100" r="200" fill="white"/>
        <circle cx="100" cy="350" r="150" fill="white"/>
      </svg>
    </div>

    <div class="relative max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm border border-white/30 rounded-full px-4 py-1.5 text-sm font-medium mb-6">
        <span class="w-2 h-2 rounded-full bg-teal-300 animate-pulse"></span>
        Clinical Training Platform — Beta
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
        Learn by Doing.<br/>
        <span class="text-teal-300">Train Like a Nurse.</span>
      </h1>

      <p class="text-xl text-white/80 leading-relaxed mb-8 max-w-2xl">
        Multi-path unfolding case studies that put you in the nurse's seat. Make real clinical decisions,
        receive evidence-based feedback, and build the critical thinking skills you need at the bedside.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-2 bg-white text-medical-700 font-bold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl hover:bg-medical-50 transition-all"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z"/>
          </svg>
          Begin Training
        </a>
        <a
          href="/references"
          class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm border border-white/30 text-white font-semibold px-6 py-3 rounded-xl hover:bg-white/30 transition-all"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
          Clinical References
        </a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="mb-12">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-slate-800 mb-2">How Multipath Works</h2>
      <p class="text-slate-500">Evidence-based learning through immersive clinical simulation</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        {
          icon: '🎯',
          title: 'Role-Based Learning',
          desc: 'You are the nurse. Every decision matters. Experience the weight of clinical responsibility in a safe environment.',
          color: 'bg-blue-50 border-blue-100',
          headingColor: 'text-blue-800',
        },
        {
          icon: '🔀',
          title: 'Branching Pathways',
          desc: 'Your choices shape the scenario. Multiple clinical paths mirror the complexity of real patient care.',
          color: 'bg-teal-50 border-teal-100',
          headingColor: 'text-teal-800',
        },
        {
          icon: '📖',
          title: 'Instant References',
          desc: 'Access drug references, assessment tools, lab values, and clinical guidelines while you work through each case.',
          color: 'bg-purple-50 border-purple-100',
          headingColor: 'text-purple-800',
        },
        {
          icon: '💬',
          title: 'Evidence-Based Feedback',
          desc: 'Detailed feedback on every decision with clinical rationale — not just right/wrong, but why.',
          color: 'bg-emerald-50 border-emerald-100',
          headingColor: 'text-emerald-800',
        },
      ].map((f) => (
        <div class={`rounded-xl border p-5 ${f.color}`}>
          <div class="text-3xl mb-3">{f.icon}</div>
          <h3 class={`text-base font-bold mb-2 ${f.headingColor}`}>{f.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Case Studies Preview -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-slate-800">Available Case Studies</h2>
        <p class="text-slate-500 text-sm mt-0.5">{allCaseStudies.length} interactive cases across multiple specialties</p>
      </div>
      <a
        href="/case-studies"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-medical-600 hover:text-medical-800 transition-colors"
      >
        View all
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {allCaseStudies.map((cs) => (
        <CaseStudyCard caseStudy={cs} />
      ))}
    </div>
  </section>

  <!-- Learning Philosophy -->
  <section class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8 mb-12">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <div>
        <h2 class="text-2xl font-bold text-slate-800 mb-4">Built on Educational Science</h2>
        <div class="space-y-4 text-slate-600">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-medical-100 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-medical-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 text-sm mb-0.5">Constructivist Learning</h3>
              <p class="text-sm">Students build clinical knowledge through active decision-making, not passive reading.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-teal-100 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 text-sm mb-0.5">Clinical Reasoning Development</h3>
              <p class="text-sm">Unfolding scenarios develop the diagnostic reasoning patterns essential for safe practice.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 text-sm mb-0.5">Safe Failure Environment</h3>
              <p class="text-sm">Mistakes in simulation are learning opportunities. Students can retry and explore all pathways.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-slate-800 text-sm mb-0.5">Evidence-Based Content</h3>
              <p class="text-sm">All clinical content is aligned with current nursing standards, guidelines, and best practices.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-gradient-to-br from-medical-50 to-teal-50 rounded-xl p-6 border border-medical-100">
        <h3 class="font-bold text-slate-800 mb-4">Quick Stats</h3>
        <div class="grid grid-cols-2 gap-4">
          {[
            { n: `${allCaseStudies.length}`, label: 'Case Studies' },
            { n: `${allCaseStudies.reduce((acc, cs) => acc + cs.scenes.length, 0)}`, label: 'Clinical Scenes' },
            { n: '8+', label: 'Drug References' },
            { n: '8', label: 'Assessment Tools' },
          ].map((s) => (
            <div class="text-center">
              <div class="text-3xl font-bold text-medical-700 mb-1">{s.n}</div>
              <div class="text-sm text-slate-500">{s.label}</div>
            </div>
          ))}
        </div>
        <div class="mt-4 pt-4 border-t border-medical-100 text-center">
          <p class="text-xs text-slate-500">Cases added regularly • Content reviewed for accuracy</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="text-center bg-gradient-to-r from-medical-600 to-teal-600 rounded-2xl p-10 text-white shadow-xl">
    <h2 class="text-3xl font-bold mb-3">Ready to Test Your Clinical Skills?</h2>
    <p class="text-white/80 text-lg mb-6 max-w-xl mx-auto">
      Each case study takes 20–35 minutes. All you need is your clinical knowledge and the willingness to think critically.
    </p>
    <a
      href="/case-studies"
      class="inline-flex items-center gap-2 bg-white text-medical-700 font-bold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl hover:bg-medical-50 transition-all text-lg"
    >
      Start a Case Study
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
      </svg>
    </a>
  </section>
</Layout>
