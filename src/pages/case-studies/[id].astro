---
import Layout from '../../layouts/Layout.astro';
import CaseStudyEngine from '../../components/CaseStudyEngine.astro';
import { allCaseStudies, getCaseStudyById } from '../../data/case-studies/index.js';

export function getStaticPaths() {
  return allCaseStudies.map((cs) => ({
    params: { id: cs.id },
  }));
}

const { id } = Astro.params;
const caseStudy = getCaseStudyById(id);

if (!caseStudy) {
  return Astro.redirect(`${import.meta.env.BASE_URL}/case-studies`);
}
---

<Layout
  title={caseStudy.title}
  description={`${caseStudy.subtitle} — ${caseStudy.description}`}
  fullWidth={true}
>
  <!-- Breadcrumb above engine -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-2">
    <div class="flex items-center gap-2 text-sm text-slate-500">
      <a href={import.meta.env.BASE_URL} class="hover:text-medical-600 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
      <a href={`${import.meta.env.BASE_URL}/case-studies`} class="hover:text-medical-600 transition-colors">Case Studies</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
      <span class="text-slate-700 font-medium truncate max-w-xs">{caseStudy.title}</span>
    </div>
  </div>

  <CaseStudyEngine caseStudy={caseStudy} />
</Layout>
