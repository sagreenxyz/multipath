---
import Layout from '../../layouts/Layout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import { allCaseStudies } from '../../data/case-studies/index.js';
---

<Layout title="Case Studies" description="Browse all available nursing case studies">
  <!-- Page header -->
  <div class="mb-8">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-2">
      <a href={import.meta.env.BASE_URL} class="hover:text-medical-600 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
      </svg>
      <span class="text-slate-700 font-medium">Case Studies</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Clinical Case Studies</h1>
    <p class="text-slate-500 mt-1">Select a case to begin. Each case places you in the role of the nurse.</p>
  </div>

  <!-- Filters / info bar -->
  <div class="flex items-center justify-between flex-wrap gap-4 mb-6 p-4 bg-white rounded-xl border border-slate-200 shadow-sm">
    <div class="flex items-center gap-4 text-sm">
      <span class="text-slate-500">{allCaseStudies.length} cases available</span>
      <div class="flex items-center gap-2">
        <span class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-800 text-xs font-medium border border-emerald-200">
          ●○○ Beginner ({allCaseStudies.filter(c => c.difficulty === 'beginner').length})
        </span>
        <span class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 text-xs font-medium border border-amber-200">
          ●●○ Intermediate ({allCaseStudies.filter(c => c.difficulty === 'intermediate').length})
        </span>
        <span class="flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-100 text-red-800 text-xs font-medium border border-red-200">
          ●●● Advanced ({allCaseStudies.filter(c => c.difficulty === 'advanced').length})
        </span>
      </div>
    </div>
    <div class="flex items-center gap-1.5 text-xs text-slate-500">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
      </svg>
      Progress is saved automatically in your browser
    </div>
  </div>

  <!-- Case list -->
  <div class="grid md:grid-cols-2 gap-6 mb-8">
    {allCaseStudies.map((cs) => (
      <CaseStudyCard caseStudy={cs} />
    ))}
  </div>

  <!-- Coming Soon placeholder -->
  <div class="bg-slate-50 rounded-xl border border-dashed border-slate-300 p-8 text-center">
    <div class="text-3xl mb-3">🚧</div>
    <h3 class="text-lg font-semibold text-slate-700 mb-2">More Cases Coming Soon</h3>
    <p class="text-sm text-slate-500 max-w-md mx-auto">
      We are actively developing additional case studies across specialties including pediatrics,
      obstetrics, mental health, and surgical care.
    </p>
  </div>

  <!-- Progress tracking note -->
  <div class="mt-6 p-4 bg-medical-50 border border-medical-200 rounded-xl flex items-start gap-3">
    <svg class="w-5 h-5 text-medical-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.601a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
    </svg>
    <div>
      <p class="text-sm font-semibold text-medical-800 mb-0.5">Your Progress</p>
      <p class="text-sm text-medical-700">Scores are saved to your browser's local storage. You can retry any case as many times as you like — explore all pathways to understand the clinical reasoning behind each decision.</p>
    </div>
  </div>
</Layout>

<script>
  // Show saved progress badges
  try {
    const saved = JSON.parse(localStorage.getItem('multipath-progress') || '{}');
    for (const [caseId, data] of Object.entries(saved as Record<string, {completed: boolean, score: number}>)) {
      if (data.completed) {
        const links = document.querySelectorAll(`a[href="${import.meta.env.BASE_URL}/case-studies/${caseId}"]`);
        links.forEach(link => {
          const badge = document.createElement('span');
          badge.className = 'ml-2 text-xs bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full border border-emerald-200 font-medium';
          badge.textContent = `Score: ${data.score}`;
          link.parentElement?.appendChild(badge);
        });
      }
    }
  } catch {}
</script>
